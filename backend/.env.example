LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
CORS_ORIGINS=http://localhost:3000

# 语义匹配 embedding（OpenAI 标准接口；缺省复用 OPENAI_* 配置，失败自动回退哈希向量）
EMBED_MODEL=text-embedding-3-small
# EMBED_BASE_URL=https://yunwu.ai/v1   # 不填则用 OPENAI_BASE_URL
# EMBED_API_KEY=sk-xxx                 # 不填则用 OPENAI_API_KEY

# 纪念长图 AI 精绘（可选；缺省时仅用即时 SVG 模拟版）
IMAGE_API_KEY=sk-xxx
IMAGE_API_URL=https://yunwu.ai/v1/images/generations
IMAGE_MODEL=gpt-image-2
